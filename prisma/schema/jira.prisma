model JiraAccount {
    id            String  @id @default(uuid())
    companyEmail  String
    companyDomain String
    apiToken      String
    active        Boolean @default(true)

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    issues JiraIssue[]

    @@unique([companyEmail, companyDomain])
    @@map("jira_accounts")
}

model JiraIssue {
    id              String @id @default(cuid())
    issueKey        String
    issueTime       Int
    totalSpentSoFar Int    @default(0)

    active    Boolean   @default(true)
    startDate DateTime?
    endDate   DateTime?

    jiraAccountId String
    jiraAccount   JiraAccount @relation(fields: [jiraAccountId], references: [id], onDelete: Cascade)

    worklogHistories WorklogHistory[]

    @@map("jira_issues")
}

model WorklogHistory {
    id            String   @id @default(cuid())
    userId        String
    secondsPerDay Int
    date          DateTime
    status        String   @default("SUCCESS") // "SUCCESS" or "FAILED"
    errorMessage  String?

    createdAt DateTime @default(now())

    issueId String
    issue   JiraIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

    @@unique([issueId, date])
    @@map("jira_worklog_histories")
}
